{
  "manifest_version": 2,
  "name": "VOLTab",
  "version": "0.1",
  "description": "Per-tab volume control for HTML media.",
  "icons": {
    "48": "icons/slider-48.png",
    "256": "icons/slider.png"
  },
"browser_specific_settings": {
  "gecko": {
    "id": "{434abde6-56ba-4073-b920-329b1d022857}",
    "data_collection_permissions": {
      "required": ["none"]
    }
  }
},
  "permissions": [
    "<all_urls>",
    "storage",
    "tabs",
    "contextMenus"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": {
      "48": "icons/slider-48.png",
      "256": "icons/slider.png"
    },
    "default_title": "VOLTab",
    "default_popup": "popup.html",
    "browser_style": true
  },
  "content_scripts": [
    {
      "matches": ["*://soundcloud.com/*", "*://*.soundcloud.com/*"],
      "js": ["soundcloud_content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false,
    "browser_style": true
  }
}
