{
  "manifest_version": 2,
  "name": "VOLTab",
  "version": "0.1",
  "description": "Per-tab volume control for HTML media.",
  "icons": {
    "48": "icons/slider.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "refried@uncool.club"
    }
  },
  "permissions": [
    "<all_urls>",
    "storage",
    "tabs",
    "contextMenus"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "Volume",
    "default_popup": "popup.html",
    "default_icon": "icons/slider.png",
    "browser_style": true
  },
  "browser_specific_settings": {
  "gecko": {
    "data_collection_permissions": {
      "required": ["none"]
     }
   }
  },
  "content_scripts": [
    {
      "matches": [
        "*://soundcloud.com/*",
        "*://*.soundcloud.com/*"
      ],
      "js": [
        "soundcloud_content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false,
    "browser_style": true
  }
}